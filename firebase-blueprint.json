{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and global settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "monthlyBudget": { "type": "number" },
        "currency": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "A recurring payment subscription",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "frequency": { "type": "string", "enum": ["monthly", "yearly", "weekly"] },
        "nextPaymentDate": { "type": "string", "format": "date-time" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "paused", "cancelled"] },
        "userId": { "type": "string" },
        "spendingLimit": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "amount", "currency", "frequency", "nextPaymentDate", "status", "userId"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A recorded payment for a subscription",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subscriptionId": { "type": "string" },
        "subscriptionName": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["completed", "failed", "pending"] },
        "userId": { "type": "string" }
      },
      "required": ["subscriptionId", "amount", "currency", "date", "status", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{userId}/subscriptions/{subscriptionId}": {
      "schema": "Subscription",
      "description": "User's recurring subscriptions"
    },
    "/users/{userId}/payments/{paymentId}": {
      "schema": "Payment",
      "description": "User's payment history"
    }
  }
}
